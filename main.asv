% Combine all data into tables
t1names = ["Airfoil","Vortex Panel","Thin Airfoil Theory","Experimental"];
alphaL0tab = table(p3names',clalpha0.vp,clalpha0.tat,clalpha0.exp,'VariableNames',t1names)

% Table form 

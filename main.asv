% Put in Table form
% Vortex Panel
clalpha0.vp = zeros(3,1);
% Thin Airfoil Theory, still need
clalpha0.tat = zeros(3,1);
% Experimental
clalpha0.exp = zeros(3,1);

for i = 1:length(p3names)-1 % remove 1 later when 0018 uploaded
